# ==============================================
# 🔐 GSSC - Variables de Entorno (Desarrollo)
# ==============================================

# ---------------------------------------------
# Sesión y Seguridad
# ---------------------------------------------
SESSION_SECRET=9KzjFMWsKOdz9VglRvbhxiqJz5qdbWnf1XQq2wrVIy4=

# ---------------------------------------------
# Google OAuth (Organizador)
# ---------------------------------------------
GOOGLE_CLIENT_ID=app-id
GOOGLE_CLIENT_SECRET=your-app-secret

# ---------------------------------------------
# Microsoft Azure AD (Proveedor)
# ---------------------------------------------
MICROSOFT_CLIENT_ID=app-id
MICROSOFT_CLIENT_SECRET=your-app-secret
MICROSOFT_TENANT_ID=tenat

# ---------------------------------------------
# Meta/Facebook (Pagador)
# ---------------------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ---------------------------------------------
# Ambiente
# ---------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------
# Backend API (Supabase REST)
# ---------------------------------------------
BACKEND_API_URL=http://localhost:54321/rest/v1
# BACKEND_API_KEY: Anon key — identifica el proyecto en cada petición REST (apikey header).
# Ya NO se usa como Bearer token. El Bearer ahora es el JWT de Supabase del usuario.
# Obtener de: supabase status → anon key
BACKEND_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
BACKEND_DB_SCHEMA=gssc_db

# URL base de Supabase (para Admin API en el BFF — sin /rest/v1)
# Local: http://localhost:54321 | Producción: https://<project-ref>.supabase.co
SUPABASE_URL=http://localhost:54321

# Service Role Key — bypasea RLS. Solo usar en servidor (BFF).
# Usado por: Admin API (upsertSupabaseAuthUser), users-client (lookups por email/registro).
# Obtener de: supabase status → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ---------------------------------------------
# Cookie Domain (dominio compartido entre subdominios)
# ---------------------------------------------
COOKIE_DOMAIN=.glam-urban.dev

# ---------------------------------------------
# Variables Públicas (Accesibles en el cliente)
# ---------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=${MICROSOFT_CLIENT_ID}

# GlamForge — Microsite de gestión de imágenes de producto
# Dev: https://glamforge-dev.glamurban.com | Stg: https://glamforge-stg.glamurban.com | Prod: https://glamforge.glam-urban.com
NEXT_PUBLIC_GLAMFORGE_URL=https://glamforge-dev.glamurban.com
