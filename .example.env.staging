# ==============================================
# 🔐 GSSC - Variables de Entorno (Staging)
# ==============================================

# ---------------------------------------------
# Sesión y Seguridad
# ---------------------------------------------
SESSION_SECRET=your-staging-session-secret

# ---------------------------------------------
# Google OAuth (Organizador)
# ---------------------------------------------
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret

# ---------------------------------------------
# Microsoft Azure AD (Proveedor)
# ---------------------------------------------
MICROSOFT_CLIENT_ID=your-staging-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-staging-microsoft-client-secret
MICROSOFT_TENANT_ID=your-staging-tenant-id

# ---------------------------------------------
# Meta/Facebook (Pagador)
# ---------------------------------------------
META_APP_ID=your-staging-meta-app-id
META_APP_SECRET=your-staging-meta-app-secret

# ---------------------------------------------
# Ambiente
# ---------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_URL=https://stagin-gssc.glam-urban.com
NEXT_PUBLIC_STAGING_URL=https://stagin-gssc.glam-urban.com
NEXTAUTH_URL=https://stagin-gssc.glam-urban.com

# ---------------------------------------------
# Backend API (Supabase REST)
# ---------------------------------------------
BACKEND_API_URL=https://your-staging-project.supabase.co/rest/v1
BACKEND_API_KEY=your-staging-anon-key
BACKEND_DB_SCHEMA=gssc_db

# URL base de Supabase (para Admin API en el BFF — sin /rest/v1)
SUPABASE_URL=https://your-staging-project.supabase.co

# Service Role Key (solo servidor, bypasea RLS)
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# ---------------------------------------------
# Cookie Domain (dominio compartido entre subdominios)
# ---------------------------------------------
COOKIE_DOMAIN=.glam-urban.com

# ---------------------------------------------
# Variables Públicas (Accesibles en el cliente)
# ---------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=${MICROSOFT_CLIENT_ID}

# GlamForge — Microsite de gestión de imágenes de producto
NEXT_PUBLIC_GLAMFORGE_URL=https://glamforge-stg.glamurban.com
